   Callback = function()
      Rayfield:Notify({
         Title = "Speed Enabled",
         Content = "You can now adjust speed using the slider",
         Duration = 3
      })
   end
})

PlayerTab:CreateSlider({
   Name = "Speed",
   Range = {16,200},
   Increment = 1,
   CurrentValue = 16,
   Callback = function(Value)

      local player = game.Players.LocalPlayer
      local humanoid = player.Character:WaitForChild("Humanoid")

      humanoid.WalkSpeed = Value

   end
})

